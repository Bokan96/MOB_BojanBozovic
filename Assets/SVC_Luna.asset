            vs_TEXCOORD1;\nhighp vec4 vs_TEXCOORD2;\nhighp vec3 vs_TEXCOORD3;\nout
            highp vec4 vs_TEXCOORD5;\nvec3 u_xlat0;\nvec4 u_xlat1;\nvec4 u_xlat2;\nbvec3
