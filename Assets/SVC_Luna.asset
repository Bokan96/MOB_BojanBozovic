            + u_xlat9.x;\n    u_xlat9.x = u_xlat9.x * 0.5 + (-u_xlat2.x);\n    vs_TEXCOORD1.x
            = (-u_xlat22) * 0.5 + u_xlat9.x;\n    u_xlat22 = (-u_xlat22) * 0.5 +
